name: Build Backport
on:
  workflow_dispatch:
  push:
    branches:
      - main

jobs:
  backport:
    runs-on: ubuntu-latest
    steps:
      - name: Check out repository
        uses: actions/checkout@v3

      - name: Install build dependencies
        run: |
          sudo apt-get update
          # Basic build tools and utilities
          sudo apt-get install -y build-essential libncurses-dev flex bison git python3-pip patch coccinelle

      - name: Clone backports and stable kernel
        run: |
          # Clone the backports framework and the desired stable kernel tag
          git clone --depth 1 https://git.kernel.org/pub/scm/linux/kernel/git/backports/backports.git
          git clone --depth 1 --branch v6.1.197 https://git.kernel.org/pub/scm/linux/kernel/git/stable/linux-stable.git linux-stable

      - name: Generate backport integration
        run: |
          cd backports
          # Integrate drivers from Linux 6.1.197 into the current repository tree
          ./gentree.py --integrate --clean --git-revision v6.1.197 ../linux-stable ${{ github.workspace }}

      - name: Archive integrated sources
        run: |
          tar -cJf backport-integration.tar.xz .

      - name: Upload artifact
        uses: actions/upload-artifact@v3
        with:
          name: backport-integration
          path: backport-integration.tar.xz
